# ═══════════════════════════════════════════════════════════
# Koib-V-4.6 — Пример конфигурации (production-ready)
# Оптимизировано для VPS: 1 vCPU / 2 ГБ RAM
# ═══════════════════════════════════════════════════════════

# === Пути ===
KOIB_DOCS_DIR=./data/docs
KOIB_OUTPUT_DIR=./output

# === LLM Provider ===
# Варианты: gigachat | openai | local
LLM_PROVIDER=gigachat

# === GigaChat ===
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.2
GIGACHAT_MAX_TOKENS=1536
GIGACHAT_TIMEOUT=45
GIGACHAT_VERIFY_SSL=false

# === OpenAI (если LLM_PROVIDER=openai) ===
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1536

# === Local LLM (если LLM_PROVIDER=local, Ollama) ===
LOCAL_LLM_MODEL=IlyaGusev/saiga_mistral_7b
LOCAL_LLM_URL=http://localhost:11434

# === Embeddings ===
# Варианты: local | openai
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Chunking ===
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=80
MIN_CHUNK_LENGTH=50

# === Retrieval ===
VECTOR_SEARCH_K=15
BM25_SEARCH_K=10
FINAL_TOP_K=4
HYBRID_ALPHA=0.6
BM25_USE_STOPWORDS=true
USE_HYDE=false

# === Reranker ===
USE_RERANKER=true
RERANKER_MODEL=DiTy/ru-reranker-base
# ★ ONNX-квантизация: обязательно true для 2 ГБ RAM (экономия ~200 МБ)
USE_ONNX_RERANKER=true

# === Parsing (PDF/DOCX) ===
# ★ 200 DPI — компромисс качество/RAM (экономия ~50% vs 300 DPI)
OCR_DPI=200
OCR_MIN_TEXT_CHARS=50
MIN_IMAGE_WIDTH=80
MIN_IMAGE_HEIGHT=80

# === Validation ===
VALIDATION_IGNORE_QUOTES=true
UNCERTAINTY_MIN_LENGTH=50

# === Semantic Cache ===
# ★ Кэш повторяющихся запросов (cosine similarity ≥ threshold)
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92

# === Concurrency (защита от OOM-спайков) ===
# ★ Максимум параллельных генераций LLM (2 = безопасно для 2 ГБ RAM)
MAX_CONCURRENT_GENERATIONS=2

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === VK Bot ===
VK_CONFIRM_CODE=12345678
VK_GROUP_ID=
VK_ACCESS_TOKEN=
